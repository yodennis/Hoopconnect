# PickupPlay Environment Configuration
# Copy this to .env and fill in your values

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=pickupplay
DB_PORT=3306

SESSION_SECRET=change_this_to_a_random_secret_string
PORT=3000

# HTTPS Configuration
USE_HTTPS=false
HTTPS_PORT=3443
REDIRECT_HTTP_TO_HTTPS=false

# SSL Certificate Paths (for production)
SSL_KEY_PATH=/etc/ssl/private/hoopconnect.key
SSL_CERT_PATH=/etc/ssl/certs/hoopconnect.crt
SSL_CA_PATH=/etc/ssl/certs/ca.crt

# SMTP Configuration (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Application URL
BASE_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
