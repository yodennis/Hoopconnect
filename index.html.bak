<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Website</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <a href="#home" class="nav-logo">
                <span class="logo-icon">&#9670;</span> MyBrand
            </a>
            <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
                <span class="hamburger"></span>
            </button>
            <ul class="nav-menu" id="navMenu">
                <li><a href="#home" class="nav-link active">Home</a></li>
                <li><a href="#about" class="nav-link">About</a></li>
                <li><a href="#services" class="nav-link">Services</a></li>
                <li><a href="#portfolio" class="nav-link">Portfolio</a></li>
                <li><a href="#contact" class="nav-link">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="hero-bg-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
        </div>
        <div class="hero-content">
            <p class="hero-subtitle">Welcome to</p>
            <h1 class="hero-title">Creative <span class="text-orange">Solutions</span></h1>
            <p class="hero-description">
                We craft stunning digital experiences that captivate audiences and drive results. 
                Let's build something extraordinary together.
            </p>
            <div class="hero-buttons">
                <a href="#services" class="btn btn-primary">Our Services</a>
                <a href="#contact" class="btn btn-outline">Get in Touch</a>
            </div>
        </div>
        <div class="scroll-indicator">
            <span>Scroll Down</span>
            <div class="scroll-arrow"></div>
        </div>
    </section>

    <!-- About Section -->
    <section class="section about" id="about">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Who We Are</p>
                <h2 class="section-title">About <span class="text-orange">Us</span></h2>
            </div>
            <div class="about-grid">
                <div class="about-text">
                    <p>
                        We are a passionate team of designers and developers dedicated to creating 
                        beautiful, functional websites and applications. With years of experience 
                        in the industry, we bring creativity and technical expertise to every project.
                    </p>
                    <p>
                        Our mission is to help businesses establish a strong online presence through 
                        innovative design and cutting-edge technology. We believe in collaboration, 
                        transparency, and delivering exceptional results.
                    </p>
                    <div class="about-stats">
                        <div class="stat">
                            <span class="stat-number" data-target="150">0</span>+
                            <span class="stat-label">Projects Completed</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number" data-target="50">0</span>+
                            <span class="stat-label">Happy Clients</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number" data-target="8">0</span>+
                            <span class="stat-label">Years Experience</span>
                        </div>
                    </div>
                </div>
                <div class="about-image">
                    <div class="image-placeholder">
                        <div class="placeholder-icon">&#9733;</div>
                        <p>Creative Team</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section class="section services" id="services">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">What We Offer</p>
                <h2 class="section-title">Our <span class="text-orange">Services</span></h2>
            </div>
            <div class="services-grid">
                <div class="service-card">
                    <div class="service-icon">&#9997;</div>
                    <h3>Web Design</h3>
                    <p>Beautiful, responsive designs that capture your brand's essence and engage your audience.</p>
                </div>
                <div class="service-card">
                    <div class="service-icon">&#128187;</div>
                    <h3>Web Development</h3>
                    <p>Custom-built websites and applications using modern technologies for optimal performance.</p>
                </div>
                <div class="service-card">
                    <div class="service-icon">&#128241;</div>
                    <h3>Mobile Apps</h3>
                    <p>Native and cross-platform mobile applications that deliver seamless user experiences.</p>
                </div>
                <div class="service-card">
                    <div class="service-icon">&#127912;</div>
                    <h3>Brand Identity</h3>
                    <p>Comprehensive branding solutions from logo design to complete visual identity systems.</p>
                </div>
                <div class="service-card">
                    <div class="service-icon">&#128200;</div>
                    <h3>SEO & Marketing</h3>
                    <p>Data-driven strategies to boost your online visibility and drive meaningful traffic.</p>
                </div>
                <div class="service-card">
                    <div class="service-icon">&#9881;</div>
                    <h3>Maintenance</h3>
                    <p>Ongoing support and maintenance to keep your digital assets running smoothly.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Portfolio Section -->
    <section class="section portfolio" id="portfolio">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Our Work</p>
                <h2 class="section-title">Featured <span class="text-orange">Projects</span></h2>
            </div>
            <div class="portfolio-grid">
                <div class="portfolio-card">
                    <div class="portfolio-image" style="background: linear-gradient(135deg, var(--orange), var(--orange-dark));">
                        <div class="portfolio-overlay">
                            <h3>E-Commerce Platform</h3>
                            <p>Web Development</p>
                        </div>
                    </div>
                </div>
                <div class="portfolio-card">
                    <div class="portfolio-image" style="background: linear-gradient(135deg, var(--blue), var(--blue-dark));">
                        <div class="portfolio-overlay">
                            <h3>Brand Redesign</h3>
                            <p>Brand Identity</p>
                        </div>
                    </div>
                </div>
                <div class="portfolio-card">
                    <div class="portfolio-image" style="background: linear-gradient(135deg, var(--blue-dark), var(--orange));">
                        <div class="portfolio-overlay">
                            <h3>Mobile Banking App</h3>
                            <p>Mobile Development</p>
                        </div>
                    </div>
                </div>
                <div class="portfolio-card">
                    <div class="portfolio-image" style="background: linear-gradient(135deg, var(--orange-dark), var(--blue));">
                        <div class="portfolio-overlay">
                            <h3>SaaS Dashboard</h3>
                            <p>UI/UX Design</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="section contact" id="contact">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Get In Touch</p>
                <h2 class="section-title">Contact <span class="text-orange">Us</span></h2>
            </div>
            <div class="contact-grid">
                <div class="contact-info">
                    <div class="contact-item">
                        <div class="contact-icon">&#128205;</div>
                        <div>
                            <h4>Address</h4>
                            <p>1 Hayden Drive, Petersburg, VA 23806</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <div class="contact-icon">&#128231;</div>
                        <div>
                            <h4>Email</h4>
                            <p>hello@mybrand.com</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <div class="contact-icon">&#128222;</div>
                        <div>
                            <h4>Phone</h4>
                            <p>(804) 555-0123</p>
                        </div>
                    </div>
                </div>
                <form class="contact-form" id="contactForm">
                    <div class="form-row">
                        <div class="form-group">
                            <input type="text" id="name" name="name" placeholder="Your Name" required>
                        </div>
                        <div class="form-group">
                            <input type="email" id="email" name="email" placeholder="Your Email" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <input type="text" id="subject" name="subject" placeholder="Subject" required>
                    </div>
                    <div class="form-group">
                        <textarea id="message" name="message" rows="5" placeholder="Your Message" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-full">Send Message</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <a href="#home" class="nav-logo">
                        <span class="logo-icon">&#9670;</span> MyBrand
                    </a>
                    <p>Crafting digital experiences that inspire and deliver results.</p>
                </div>
                <div class="footer-links">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="#home">Home</a></li>
                        <li><a href="#about">About</a></li>
                        <li><a href="#services">Services</a></li>
                        <li><a href="#contact">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-social">
                    <h4>Follow Us</h4>
                    <div class="social-links">
                        <a href="#" class="social-link" aria-label="Twitter">&#120143;</a>
                        <a href="#" class="social-link" aria-label="LinkedIn">in</a>
                        <a href="#" class="social-link" aria-label="GitHub">&#9679;</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 MyBrand. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>
